# ============================================================
# IndiaLexABSA — Environment Variables Template
# Copy this file to .env and fill in your actual keys
# NEVER commit .env to version control
# ============================================================

# ── LLM API Keys (pick ONE — all are FREE!) ──────────────────
# Option 1: Google Gemini (FREE) — Get key at https://aistudio.google.com
GEMINI_API_KEY=your_gemini_key_here

# Option 2: Groq (FREE) — Get key at https://console.groq.com
GROQ_API_KEY=your_groq_key_here

# HuggingFace Token (required for pushing dataset/models to Hub)
HUGGINGFACE_TOKEN=hf_your_token_here

# Weights & Biases (optional, for experiment tracking)
WANDB_API_KEY=your_wandb_key_here
WANDB_PROJECT=indialexabsa
WANDB_ENTITY=your_wandb_username

# MCA Portal credentials (if required for scraping)
MCA_USERNAME=
MCA_PASSWORD=

# Paths (override defaults if needed)
DATA_DIR=data/
PROCESSED_DIR=data/processed/
CHROMADB_PATH=data/chromadb/
MODEL_CACHE_DIR=models/cache/

# Dashboard settings
DEMO_MODE=true
MAX_UPLOAD_MB=50
